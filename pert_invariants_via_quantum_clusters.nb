Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Z31", "=", 
    RowBox[{
     SubscriptBox["hR", 
      RowBox[{"1", ",", "5"}]], 
     SubscriptBox["hR", 
      RowBox[{"6", ",", "2"}]], 
     SubscriptBox["hR", 
      RowBox[{"3", ",", "7"}]], 
     SubscriptBox["C", "4"], 
     SubscriptBox["hv", "8"], 
     SubscriptBox["hv", "9"], 
     SubscriptBox["hv", "10"]}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"Z", " ", "of", " ", 
    RowBox[{"(", 
     RowBox[{"right", "-", "handed"}], ")"}], "Trefoil"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Do", "[", 
  RowBox[{
   RowBox[{"Z31", "=", 
    RowBox[{"Z31", "//", 
     SubscriptBox["hm", 
      RowBox[{"i", ",", 
       RowBox[{"1", "->", "1"}]}]]}]}], ",", 
