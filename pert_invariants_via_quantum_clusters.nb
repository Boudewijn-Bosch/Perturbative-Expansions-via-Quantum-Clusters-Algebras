Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["\[Mu]q", "k_"], "[", "Z_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"X", ",", "B", ",", "n"}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"X", ",", "B"}], "}"}], "=", "Z"}], " ", ";", " ", 
      RowBox[{"n", "=", 
       RowBox[{"Length", "[", "X", "]"}]}], ";", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"i", "==", "k"}], ",", 
            RowBox[{"inv", "[", 
             RowBox[{"X", "[", 
              RowBox[{"[", "k", "]"}], "]"}], "]"}], ",", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"B", "[", 
                RowBox[{"[", 
                 RowBox[{"k", ",", "i"}], "]"}], "]"}], ">=", "0"}], ",", 
              RowBox[{
               RowBox[{"X", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "**", 
               RowBox[{"Product", "[", 
                RowBox[{
                 RowBox[{"inv", "[", 
                  RowBox[{"(", 
                   RowBox[{"1", "+", 
                    RowBox[{
                    SuperscriptBox["q", 
                    RowBox[{
                    RowBox[{"2", "m"}], "-", "1"}]], 
                    RowBox[{"inv", "[", 
                    RowBox[{"X", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], "]"}]}]}], ")"}], "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"m", ",", "1", ",", 
                   RowBox[{"B", "[", 
                    RowBox[{"[", 
                    RowBox[{"k", ",", "i"}], "]"}], "]"}]}], "}"}]}], "]"}]}],
               ",", 
              RowBox[{
               RowBox[{"X", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "**", 
               RowBox[{"Product", "[", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"1", "+", 
                   RowBox[{
                    SuperscriptBox["q", 
                    RowBox[{
                    RowBox[{"2", "m"}], "-", "1"}]], 
                    RowBox[{"X", "[", 
                    RowBox[{"[", "k", "]"}], "]"}]}]}], ")"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"m", ",", "1", ",", 
                   RowBox[{"-", 
                    RowBox[{"B", "[", 
                    RowBox[{"[", 
                    RowBox[{"k", ",", "i"}], "]"}], "]"}]}]}], "}"}]}], 
                "]"}]}]}], "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"i", "==", "k"}], " ", "||", " ", 
               RowBox[{"j", "==", "k"}]}], ",", 
              RowBox[{"-", 
               RowBox[{"B", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", "j"}], "]"}], "]"}]}], ",", 
              RowBox[{
               RowBox[{"B", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", "j"}], "]"}], "]"}], "+", 
               FractionBox[
                RowBox[{
                 RowBox[{
                  RowBox[{"B", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", "k"}], "]"}], "]"}], 
                  RowBox[{"Abs", "[", 
                   RowBox[{"B", "[", 
                    RowBox[{"[", 
                    RowBox[{"k", ",", "j"}], "]"}], "]"}], "]"}]}], " ", "+", 
                 " ", 
                 RowBox[{
                  RowBox[{"Abs", "[", 
                   RowBox[{"B", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", "k"}], "]"}], "]"}], "]"}], 
                  RowBox[{"B", "[", 
                   RowBox[{"[", 
                    RowBox[{"k", ",", "j"}], "]"}], "]"}]}]}], "2"]}]}], 
             "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}], "}"}]}]}], 
    "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{" ", 
  RowBox[{
   RowBox[{"Rq", "[", 
    RowBox[{"V_", ",", "B_"}], "]"}], ":=", 
