Cell[CellGroupData[{

Cell["Classical mutations", "Subsection",
 CellChangeTimes->{{3.956292615475011*^9, 
  3.9562926283735313`*^9}},ExpressionUUID->"9ea32120-0a55-40b2-a7b2-\
54beaef0de32"],

Cell[TextData[{
 "The function ",
 StyleBox["\[Mu]", "Input"],
 " takes as input a list ",
 StyleBox["Z", "Input"],
 " with two elements: the cluster variables  ",
 StyleBox["X", "Input"],
 " and the exchange matrix ",
 StyleBox["B", "Input"],
 ". The index ",
 StyleBox["k", "Input"],
 " specifies which cluster variable to mutate. The function returns a new \
list containing the updated cluster variables and exchange matrix after \
mutation. Moreover, the function ",
 StyleBox["ExchangeMatrixQuiver ", "Input"],
 "generates the sl2 quiver associated to the n-punctured disk."
}], "Text",
 CellChangeTimes->{
  3.980323239933208*^9, {3.9803233380807457`*^9, 3.9803233461533737`*^9}, {
   3.980580371654214*^9, 3.980580389011009*^9}, {3.9805837958182383`*^9, 
   3.980583824997807*^9}, {3.98058391324743*^9, 3.980583917187737*^9}, {
   3.9810103451745157`*^9, 3.9810105344639378`*^9}, {3.981701375872451*^9, 
   3.9817013767356787`*^9}},ExpressionUUID->"2379e2b4-3d4f-449a-a5e2-\
d848c26d900e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["\[Mu]", "k_"], "[", "Z_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"X", ",", "B", ",", "n"}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"X", ",", "B"}], "}"}], "=", "Z"}], ";", "\[IndentingNewLine]", 
     RowBox[{"n", "=", 
      RowBox[{"Length", "[", "X", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"i", "==", "k"}], ",", 
           SuperscriptBox[
            RowBox[{"X", "[", 
             RowBox[{"[", "i", "]"}], "]"}], 
            RowBox[{"-", "1"}]], ",", 
           RowBox[{
            RowBox[{"X", "[", 
             RowBox[{"[", "i", "]"}], "]"}], " ", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"1", "+", 
               SuperscriptBox[
                RowBox[{"X", "[", 
                 RowBox[{"[", "k", "]"}], "]"}], 
                RowBox[{"-", 
                 RowBox[{"Sign", "[", 
                  RowBox[{"B", "[", 
                   RowBox[{"[", 
                    RowBox[{"k", ",", "i"}], "]"}], "]"}], "]"}]}]]}], ")"}], 
             
             RowBox[{"-", 
              RowBox[{"B", "[", 
               RowBox[{"[", 
                RowBox[{"k", ",", "i"}], "]"}], "]"}]}]]}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "n"}], "}"}]}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"i", "==", "k"}], "||", 
            RowBox[{"j", "==", "k"}]}], ",", 
           RowBox[{"-", 
            RowBox[{"B", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "j"}], "]"}], "]"}]}], ",", 
           RowBox[{
            RowBox[{"B", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "j"}], "]"}], "]"}], "+", 
            FractionBox[
             RowBox[{
              RowBox[{
               RowBox[{"B", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", "k"}], "]"}], "]"}], " ", 
               RowBox[{"Abs", "[", 
                RowBox[{"B", "[", 
                 RowBox[{"[", 
                  RowBox[{"k", ",", "j"}], "]"}], "]"}], "]"}]}], "+", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"B", "[", 
                 RowBox[{"[", 
                  RowBox[{"i", ",", "k"}], "]"}], "]"}], "]"}], " ", 
               RowBox[{"B", "[", 
                RowBox[{"[", 
                 RowBox[{"k", ",", "j"}], "]"}], "]"}]}]}], "2"]}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "n"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "n"}], "}"}]}], "]"}]}], "}"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Quiver", "[", "Z_", "]"}], ":=", 
   RowBox[{"AdjacencyGraph", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Z", "+", " ", 
        RowBox[{"Transpose", "[", 
         RowBox[{"Abs", "[", "Z", "]"}], "]"}]}], ")"}], "/", "2"}], ",", 
     RowBox[{"VertexLabels", "->", "Automatic"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"QuiverEdges", "[", "n_", "]"}], ":=", 
   RowBox[{"Flatten", "@", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"b", "=", 
          RowBox[{
           RowBox[{"3", " ", "k"}], "+", "1"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"b", "->", 
           RowBox[{"b", "+", "1"}]}], ",", 
          RowBox[{
           RowBox[{"b", "+", "1"}], "->", 
           RowBox[{"b", "+", "3"}]}], ",", 
          RowBox[{
           RowBox[{"b", "+", "3"}], "->", 
           RowBox[{"b", "+", "2"}]}], ",", 
          RowBox[{
           RowBox[{"b", "+", "2"}], "->", "b"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", 
        RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ExchangeMatrixQuiver", "[", "n_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Nverts", ",", "edges", ",", "pos"}], "}"}], ",", 
     RowBox[{
      RowBox[{"Nverts", "=", 
       RowBox[{
        RowBox[{"3", " ", "n"}], "+", "1"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"edges", "=", 
       RowBox[{"QuiverEdges", "[", "n", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"pos", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"List", "@@", "#"}], ")"}], "&"}], "/@", "edges"}]}], ";", 
      RowBox[{"(*", 
       RowBox[{"list", " ", "of", " ", 
        RowBox[{"{", 
         RowBox[{"u", ",", "v"}], "}"}]}], "*)"}], 
      RowBox[{"SparseArray", "[", 
       RowBox[{
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"#", "->", "1"}], ")"}], "&"}], "/@", "pos"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Reverse", "[", "#", "]"}], "->", 
              RowBox[{"-", "1"}]}], ")"}], "&"}], "/@", "pos"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"Nverts", ",", "Nverts"}], "}"}]}], "]"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Sigma]", "[", 
    RowBox[{"n_", ",", "i_", ",", "j_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "I", "}"}], ",", 
     RowBox[{
      RowBox[{"I", "=", 
       RowBox[{"IdentityMatrix", "[", "n", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"I", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "j"}], "}"}]}], "]"}], "]"}], "=", 
       RowBox[{"I", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "i"}], "}"}]}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "I"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"M", "[", 
   RowBox[{"n_", ",", "i_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"\[Sigma]", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"3", "n"}], "+", "1"}], ",", 
     RowBox[{"3", "i"}], ",", 
     RowBox[{
      RowBox[{"3", "i"}], "+", "2"}]}], "]"}], ".", 
   RowBox[{"\[Sigma]", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"3", "n"}], "+", "1"}], ",", 
     RowBox[{
      RowBox[{"3", "i"}], "-", "1"}], ",", 
     RowBox[{
      RowBox[{"3", "i"}], "+", "2"}]}], "]"}], ".", 
   RowBox[{"\[Sigma]", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"3", "n"}], "+", "1"}], ",", 
     RowBox[{"3", "i"}], ",", 
     RowBox[{
      RowBox[{"3", "i"}], "+", "3"}]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"B", "=", 
   RowBox[{
    RowBox[{"ExchangeMatrixQuiver", "[", "2", "]"}], "//", "Normal"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"V", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     SubscriptBox["v", "i"], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "7"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Rgen", "[", 
   RowBox[{"V_", ",", "B_", ",", "n_", ",", "i_"}], "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"M", "=", " ", 
      RowBox[{"M", "[", 
       RowBox[{"n", ",", "i"}], "]"}]}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"M", ".", "#1"}], ",", 
        RowBox[{"M", ".", "#2", ".", 
         RowBox[{"Transpose", "[", "M", "]"}]}]}], "}"}], "&"}], "@@", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"V", ",", "B"}], "}"}], "//", 
          SubscriptBox["\[Mu]", 
           RowBox[{
            RowBox[{"3", "i"}], "+", "1"}]]}], "//", 
         SubscriptBox["\[Mu]", 
          RowBox[{
           RowBox[{"3", "i"}], "+", "3"}]]}], "//", 
        SubscriptBox["\[Mu]", 
         RowBox[{
          RowBox[{"3", "i"}], "-", "1"}]]}], "//", 
       SubscriptBox["\[Mu]", 
        RowBox[{
         RowBox[{"3", "i"}], "+", "1"}]]}], ")"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Rgeninv", "[", 
    RowBox[{"V_", ",", "B_", ",", "n_", ",", "i_"}], "]"}], ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", " ", 
       RowBox[{
        RowBox[{"\[Sigma]", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"3", "n"}], "+", "1"}], ",", 
          RowBox[{"3", "i"}], ",", 
          RowBox[{
           RowBox[{"3", "i"}], "+", "3"}]}], "]"}], ".", 
        RowBox[{"\[Sigma]", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"3", "n"}], "+", "1"}], ",", 
          RowBox[{
           RowBox[{"3", "i"}], "-", "1"}], ",", 
          RowBox[{
           RowBox[{"3", "i"}], "+", "2"}]}], "]"}], ".", 
        RowBox[{"\[Sigma]", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"3", "n"}], "+", "1"}], ",", 
          RowBox[{"3", "i"}], ",", 
          RowBox[{
           RowBox[{"3", "i"}], "+", "2"}]}], "]"}]}]}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"M", ".", "#1"}], ",", 
         RowBox[{"M", ".", "#2", ".", 
          RowBox[{"Transpose", "[", "M", "]"}]}]}], "}"}], "&"}], "@@", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"V", ",", "B"}], "}"}], "//", 
           SubscriptBox["\[Mu]", 
            RowBox[{
             RowBox[{"3", "i"}], "+", "1"}]]}], "//", 
          SubscriptBox["\[Mu]", 
           RowBox[{"3", "i"}]]}], "//", 
         SubscriptBox["\[Mu]", 
          RowBox[{
           RowBox[{"3", "i"}], "+", "2"}]]}], "//", 
        SubscriptBox["\[Mu]", 
         RowBox[{
          RowBox[{"3", "i"}], "+", "1"}]]}], ")"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"R", "[", 
