 RowBox[{
  RowBox[{
   RowBox[{"ClusterVar", "[", "n_", "]"}], ":=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{"i", "==", "1"}], ",", 
       RowBox[{"I", " ", 
        SuperscriptBox["T", 
         RowBox[{"-", "1"}]], " ", 
        SubscriptBox["x", "1"]}], ",", 
       RowBox[{"i", "==", "2"}], ",", 
       RowBox[{"-", 
        SuperscriptBox["T", "2"]}], ",", 
       RowBox[{"i", "==", "3"}], ",", 
       RowBox[{"-", "1"}], ",", 
       RowBox[{"i", "==", 
        RowBox[{
         RowBox[{"3", " ", "n"}], "+", "1"}]}], ",", 
       RowBox[{"I", " ", 
        SuperscriptBox[
         SubscriptBox["x", "n"], 
         RowBox[{"-", "1"}]]}], ",", 
       RowBox[{
        RowBox[{"Mod", "[", 
         RowBox[{"i", ",", "3"}], "]"}], "==", "1"}], ",", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["T", 
          RowBox[{"-", "1"}]]}], " ", 
        SuperscriptBox[
         SubscriptBox["x", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"i", "-", "1"}], ")"}], "/", "3"}]], 
         RowBox[{"-", "1"}]], 
        SubscriptBox["x", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"i", "+", "2"}], ")"}], "/", "3"}]]}], ",", 
       RowBox[{
        RowBox[{"Mod", "[", 
         RowBox[{"i", ",", "3"}], "]"}], "==", "2"}], ",", 
       RowBox[{"-", 
        RowBox[{"T", "^", "2"}]}], ",", 
       RowBox[{
        RowBox[{"Mod", "[", 
         RowBox[{"i", ",", "3"}], "]"}], "==", "0"}], ",", 
       RowBox[{"-", "1"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{
        RowBox[{"3", " ", "n"}], "+", "1"}]}], "}"}]}], "]"}]}], 
  ";"}]}], "Input",
