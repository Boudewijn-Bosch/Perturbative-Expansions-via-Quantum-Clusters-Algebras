      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"M", ".", "#1"}], ",", 
         RowBox[{"M", ".", "#2", ".", 
          RowBox[{"Transpose", "[", "M", "]"}]}]}], "}"}], "&"}], "@@", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"V", ",", "B"}], "}"}], "//", 
           SubscriptBox["\[Mu]q", "4"]}], "//", 
          SubscriptBox["\[Mu]q", "6"]}], "//", 
         SubscriptBox["\[Mu]q", "2"]}], "//", 
        SubscriptBox["\[Mu]q", "4"]}], ")"}]}]}], "]"}]}]}]}], "Input",
 InitializationCell->True,
