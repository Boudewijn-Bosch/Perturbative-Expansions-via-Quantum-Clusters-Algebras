Cell[CellGroupData[{

Cell["Relations", "Subsection",
 CellChangeTimes->{{3.951537273080916*^9, 
  3.951537277327408*^9}},ExpressionUUID->"b051c866-99c3-46cd-99b2-\
47d586df5d53"],

Cell[TextData[{
 "Let us start by initializing the relations within the package ",
 StyleBox["NCAlgebra", "Input"],
 ", as shown below. To do this, we need to define the commutative and \
non-commutative variables. Among the non-commutative variables, an order \
needs to be specified. The array ",
 StyleBox["RelsHB", "Input"],
 " specifies the relations of the Weyl-Heisenberg algebra. The array ",
 StyleBox["RelsQT", "Input"],
 " specifies the relations of the quantum torus algebra. Note that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Z", "i"], TraditionalForm]],ExpressionUUID->
  "56b24847-8b76-401b-b690-6aac14dc86f9"],
 " = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"inv", " ", 
    SubscriptBox["Y", "i"]}], TraditionalForm]],ExpressionUUID->
  "ed0fa99a-b0d8-4ca5-a90a-354a29b0b7fa"],
 ". Lastly, ",
 StyleBox["gbqt", "Input"],
 " and ",
 StyleBox["gbhb", "Input"],
 " produces a Gr\[ODoubleDot]bner basis associated to the list of polynomials \
",
 StyleBox["RelsQT", "Input"],
 " and ",
 StyleBox["RelsHB", "Input"],
 ", respectively. The ",
 StyleBox["NCMakeGB", "Input"],
 " algorithm performs at most k iterations to compute a Gr\[ODoubleDot]bner \
basis for the input list of polynomials, relative to the monomial order."
}], "Text",
 CellChangeTimes->{{3.98032823950064*^9, 3.980328387996233*^9}, {
  3.9803294260765963`*^9, 3.9803294277871723`*^9}, {3.980332800449834*^9, 
  3.980332827653026*^9}, {3.980580436318047*^9, 3.9805804393848457`*^9}, {
  3.98058137980236*^9, 3.980581401174684*^9}, {3.98058151315378*^9, 
  3.9805815142293262`*^9}, {3.980583935984642*^9, 
  3.980583963068863*^9}},ExpressionUUID->"bb8952d3-b349-442d-8cca-\
0dbd24d09489"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetCommutative", "[", 
   RowBox[{"q", ",", "\[Epsilon]"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SetNonCommutative", "[", 
   RowBox[{"x", ",", "y", ",", "Y", ",", "Z"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SetMonomialOrder", "[", 
   RowBox[{
    SubscriptBox["x", "1"], ",", 
    SuperscriptBox[
     SubscriptBox["x", "1"], 
     RowBox[{"-", "1"}]], ",", 
    SubscriptBox["x", "2"], ",", 
    SuperscriptBox[
     SubscriptBox["x", "2"], 
     RowBox[{"-", "1"}]], ",", 
    SubscriptBox["p", "1"], ",", 
    SubscriptBox["p", "2"], ",", 
    SubscriptBox["Y", "1"], ",", 
    SubscriptBox["Y", "2"], ",", 
    SubscriptBox["Z", "1"], ",", 
    SubscriptBox["Z", "2"]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Rels", "[", "n_", "]"}], ":=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["x", "1"], " ", "**", " ", 
       SubscriptBox["Y", "1"]}], " ", "-", 
      RowBox[{
       SuperscriptBox["q", 
        RowBox[{"-", "n"}]], " ", 
       RowBox[{
        SubscriptBox["Y", "1"], " ", "**", 
        SubscriptBox["x", "1"]}]}]}], ",", " ", 
     RowBox[{
      RowBox[{
       SubscriptBox["x", "1"], " ", "**", 
       SubscriptBox["x", "2"]}], "-", 
      RowBox[{
       SubscriptBox["x", "2"], "**", 
       SubscriptBox["x", "1"]}]}], ",", 
     RowBox[{
      RowBox[{
       SubscriptBox["Y", "1"], "**", 
       SubscriptBox["Y", "2"]}], "-", 
      RowBox[{
       SubscriptBox["Y", "2"], "**", 
       SubscriptBox["Y", "1"]}]}], ",", " ", 
     RowBox[{
      RowBox[{
       SubscriptBox["x", "1"], "**", 
       SubscriptBox["Y", "2"]}], "-", 
      RowBox[{
       SubscriptBox["Y", "2"], "**", 
       SubscriptBox["x", "1"]}]}], ",", " ", 
     RowBox[{
      RowBox[{
       SubscriptBox["x", "2"], "**", 
       SubscriptBox["Y", "1"]}], "-", 
      RowBox[{
       SubscriptBox["Y", "1"], "**", 
       SubscriptBox["x", "2"]}]}], ",", " ", 
     RowBox[{
      RowBox[{
       SubscriptBox["x", "2"], " ", "**", 
       SubscriptBox["Y", "2"]}], "-", 
      RowBox[{
       SuperscriptBox["q", 
        RowBox[{"-", "n"}]], " ", 
       RowBox[{
        SubscriptBox["Y", "2"], "**", 
        SubscriptBox["x", "2"]}]}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
