Cell[CellGroupData[{

Cell["Input and functions", "Subsection",
 CellChangeTimes->{{3.956295437755246*^9, 3.956295438307291*^9}, {
  3.956815969780521*^9, 
  3.956815973433876*^9}},ExpressionUUID->"9ed692ac-de1a-4821-a8d6-\
4d6e40aed8ae"],

Cell[TextData[{
 "This list input defines the quantum cluster variables as in (6.2). The \
function ",
 StyleBox["NormalOrder", "Input"],
 " normal orders exponents in accordance with Proposition 3.5. The function \
",
 StyleBox["ExpandExponents", "Input"],
 " merely expands exponents, without placing them in a normal ordered format. \
The function ",
 StyleBox["P", "Input"],
 " interchanges tensor factors. ",
 StyleBox["NCIntp", "Input"],
 " provides functionality for integrating expressions involving Heisenberg \
operators with respect to the variables ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "i"], TraditionalForm]],ExpressionUUID->
  "c8178914-871f-40a1-a784-8ffc7a10dba9"],
 "."
}], "Text",
 CellChangeTimes->{{3.9803284805281982`*^9, 3.9803284995534*^9}, {
  3.9803321019922*^9, 3.980332130258419*^9}, {3.9805815193509893`*^9, 
