Cell[BoxData[{
 RowBox[{
  RowBox[{"$k", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"input", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"I", " ", 
      SubscriptBox[
       StyleBox["x",
        FontWeight->"Plain"], "1"], " ", 
      SuperscriptBox["T", 
       RowBox[{"-", "1"}]]}], ",", 
     RowBox[{
      RowBox[{"-", " ", "q"}], " ", 
      SuperscriptBox["T", "2"], " ", 
      SuperscriptBox[
       SubscriptBox["Y", "1"], "2"]}], " ", ",", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["q", 
        RowBox[{"-", "1"}]]}], " ", 
      SuperscriptBox[
       SubscriptBox["Z", "1"], "2"]}], ",", 
     RowBox[{
      RowBox[{"-", " ", 
       SuperscriptBox["T", 
        RowBox[{"-", "1"}]]}], " ", 
      RowBox[{
       SuperscriptBox[
        SubscriptBox["x", "1"], 
        RowBox[{"-", "1"}]], "**", 
       SubscriptBox["x", "2"]}]}], "  ", ",", 
     RowBox[{
      RowBox[{"-", " ", "q"}], " ", 
      SuperscriptBox["T", "2"], " ", 
      SuperscriptBox[
       SubscriptBox["Y", "1"], "2"]}], " ", ",", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["q", 
        RowBox[{"-", "1"}]]}], 
      SuperscriptBox[
       SubscriptBox["Z", "2"], "2"]}], ",", 
     RowBox[{"I", " ", 
      SuperscriptBox[
       SubscriptBox["x", "2"], 
       RowBox[{"-", "1"}]]}]}], "}"}]}], " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"NormalOrder", "[", "F_", "]"}], ":=", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Expand", "[", "F", "]"}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          SuperscriptBox[
           SubscriptBox["Z", "1"], "n_"], "->", 
          SuperscriptBox[
           SubscriptBox["Y", "1"], 
           RowBox[{"-", "n"}]]}], ",", 
         RowBox[{
          SuperscriptBox[
           SubscriptBox["Z", "2"], "n_"], "->", 
          SuperscriptBox[
           SubscriptBox["Y", "2"], 
           RowBox[{"-", "n"}]]}]}], "}"}]}], ")"}], "/.", 
     RowBox[{"{", 
      RowBox[{
       SuperscriptBox[
        SubscriptBox["Y", "k_"], "n_"], "->", 
       RowBox[{"Sum", "[", 
        RowBox[{
         FractionBox[
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox["q", "n"], "-", "1"}], ")"}], "i"], " ", 
           RowBox[{
            SuperscriptBox[
             SubscriptBox["x", "k"], "i"], "**", 
            SuperscriptBox[
             SubscriptBox["p", "k"], "i"]}]}], 
          RowBox[{"i", "!"}]], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "0", ",", "$k"}], "}"}]}], "]"}]}], "}"}]}], 
    ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ExpandExponents", "[", "F_", "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Expand", "[", "F", "]"}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         SubscriptBox["Z", "1"], "n_"], "->", 
        SuperscriptBox[
         SubscriptBox["Y", "1"], 
         RowBox[{"-", "n"}]]}], ",", 
       RowBox[{
        SuperscriptBox[
         SubscriptBox["Z", "2"], "n_"], "->", 
        SuperscriptBox[
         SubscriptBox["Y", "2"], 
         RowBox[{"-", "n"}]]}]}], "}"}]}], ")"}], "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       SubscriptBox["Y", "1"], "n_"], "->", " ", 
      RowBox[{"Sum", "[", 
       RowBox[{
        FractionBox[
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"n", " ", "\[Epsilon]", " ", 
            RowBox[{
             SubscriptBox["x", "1"], "**", 
             SubscriptBox["p", "1"]}]}], ")"}], "k"], 
         RowBox[{"k", "!"}]], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", "$k"}], "}"}]}], "]"}]}], ",", 
     RowBox[{
      SuperscriptBox[
       SubscriptBox["Y", "2"], "n_"], "->", 
      RowBox[{"Sum", "[", 
       RowBox[{
        FractionBox[
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"n", " ", "\[Epsilon]", " ", 
            RowBox[{
             SubscriptBox["x", "2"], "**", 
             SubscriptBox["p", "2"]}]}], ")"}], "k"], 
         RowBox[{"k", "!"}]], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", "$k"}], "}"}]}], "]"}]}], ",", 
     RowBox[{
      SubscriptBox["Y", "1"], "->", " ", 
      RowBox[{"Sum", "[", 
       RowBox[{
        FractionBox[
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"\[Epsilon]", " ", 
            RowBox[{
             SubscriptBox["x", "1"], "**", 
             SubscriptBox["p", "1"]}]}], ")"}], "k"], 
         RowBox[{"k", "!"}]], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", "$k"}], "}"}]}], "]"}]}], ",", 
     RowBox[{
      SubscriptBox["Y", "2"], "->", " ", 
      RowBox[{"Sum", "[", 
       RowBox[{
        FractionBox[
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"\[Epsilon]", " ", 
            RowBox[{
             SubscriptBox["x", "2"], "**", 
             SubscriptBox["p", "2"]}]}], ")"}], "k"], 
         RowBox[{"k", "!"}]], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", "$k"}], "}"}]}], "]"}]}]}], "}"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"P", "[", "F_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Expand", "[", "F", "]"}], "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SubscriptBox["x", "1"], "->", 
      SubscriptBox["x", "2"]}], ",", 
     RowBox[{
      SubscriptBox["x", "2"], "->", 
      SubscriptBox["x", "1"]}], ",", 
     RowBox[{
      SubscriptBox["p", "1"], "->", 
      SubscriptBox["p", "2"]}], ",", 
     RowBox[{
      SubscriptBox["p", "2"], "->", 
      SubscriptBox["p", "1"]}]}], "}"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ApplyR0", "[", "F_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Expand", "[", "F", "]"}], "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SubscriptBox["x", "1"], "->", 
      RowBox[{
       RowBox[{
        SuperscriptBox["T", 
         RowBox[{"-", "1"}]], " ", 
        SubscriptBox["x", "1"]}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          SuperscriptBox["T", 
           RowBox[{"-", "2"}]]}], ")"}], 
        SubscriptBox["x", "2"]}]}]}], ",", 
     RowBox[{
      SubscriptBox["x", "2"], "->", 
      RowBox[{
       SuperscriptBox["T", 
        RowBox[{"-", "1"}]], 
       SubscriptBox["x", "2"]}]}], ",", 
     RowBox[{
      SubscriptBox["p", "1"], "->", 
      RowBox[{"T", " ", 
       SubscriptBox["p", "1"]}]}], ",", 
     RowBox[{
      SubscriptBox["p", "2"], "->", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          SuperscriptBox["T", "2"]}], ")"}], 
        SubscriptBox["p", "1"]}], "+", 
       RowBox[{"T", " ", 
        SubscriptBox["p", "2"]}]}]}]}], "}"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"NCIntp", "[", 
   RowBox[{"F_", ",", "i_"}], "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"NCExpandReplaceRepeated", "[", 
    RowBox[{
     RowBox[{"NCExpand", "[", 
      RowBox[{"F", "**", 
       SubscriptBox["p", "i"]}], "]"}], ",", "gbhb"}], "]"}], "/.", 
   RowBox[{"{", 
    RowBox[{
     SuperscriptBox[
      SubscriptBox["p", "i"], "n_"], "->", " ", 
     RowBox[{
      FractionBox["1", "n"], 
      SuperscriptBox[
       SubscriptBox["p", "i"], "n"]}]}], "}"}]}]}]}], "Input",
