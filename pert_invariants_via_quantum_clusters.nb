Cell[BoxData[{
 RowBox[{
  RowBox[{"NCSeries", "[", 
   RowBox[{"f_", ",", 
    RowBox[{"{", 
     RowBox[{"x_", ",", "x0_", ",", "n_"}], "}"}]}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "H", "}"}], ",", 
    RowBox[{
     RowBox[{"SetNonCommutative", "[", "H", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"Plus", "@@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"1", "/", 
             RowBox[{"i", "!"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "0", ",", "n"}], "}"}]}], "]"}], "*", 
          RowBox[{"NestList", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"NCDirectionalD", "[", 
              RowBox[{"#", ",", 
               RowBox[{"{", 
                RowBox[{"x", ",", "H"}], "}"}]}], "]"}], "&"}], ",", "f", ",",
             "n"}], "]"}]}], ")"}]}], "/.", " ", 
       RowBox[{"x", "->", "x0"}]}], "/.", " ", 
      RowBox[{"H", "->", "x"}]}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["F", "1"], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"-", "I"}], "*", "T", "*", 
            RowBox[{
             RowBox[{"Rq", "[", 
              RowBox[{"input", ",", "B"}], "]"}], "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "//", 
           RowBox[{
            RowBox[{"NCExpandReplaceRepeated", "[", 
             RowBox[{"#", ",", "gbqt"}], "]"}], "&"}]}], "//", 
          "NormalOrder"}], "//", "NCExpand"}], "//", 
        RowBox[{
         RowBox[{"ReplaceAll", "[", 
          RowBox[{"#", ",", 
           RowBox[{"q", "->", 
            RowBox[{"Exp", "[", "\[Epsilon]", "]"}]}]}], "]"}], "&"}]}], "//", 
       RowBox[{
        RowBox[{"Series", "[", 
         RowBox[{"#", ",", 
          RowBox[{"{", 
           RowBox[{"\[Epsilon]", ",", "0", ",", "2"}], "}"}]}], "]"}], 
        "&"}]}], "//", "Normal"}], "//", "P"}], "//", "ApplyR0"}], "//", 
   RowBox[{
    RowBox[{"NCExpandReplaceRepeated", "[", 
     RowBox[{"#", ",", "gbhb"}], "]"}], "&"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["F", "2"], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"-", "I"}], "*", 
            RowBox[{
             RowBox[{"Rq", "[", 
              RowBox[{"input", ",", "B"}], "]"}], "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "7"}], "]"}], "]"}]}], "//", 
           RowBox[{
            RowBox[{"NCExpandReplaceRepeated", "[", 
             RowBox[{"#", ",", "gbqt"}], "]"}], "&"}]}], "//", 
          RowBox[{
           RowBox[{"ReplaceAll", "[", 
            RowBox[{"#", ",", 
             RowBox[{"q", "->", 
              RowBox[{"Exp", "[", "\[Epsilon]", "]"}]}]}], "]"}], "&"}]}], "//",
          "ExpandExponents"}], "//", "inv"}], "//", 
       RowBox[{
        RowBox[{"NCSeries", "[", 
         RowBox[{"#", ",", 
          RowBox[{"{", 
           RowBox[{"\[Epsilon]", ",", "0", ",", "2"}], "}"}]}], "]"}], 
        "&"}]}], "//", "Normal"}], "//", "P"}], "//", "ApplyR0"}], "//", 
   RowBox[{
    RowBox[{"NCExpandReplaceRepeated", "[", 
     RowBox[{"#", ",", "gbhb"}], "]"}], "&"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["f", "1"], ",", 
     SubscriptBox["f", "2"]}], "}"}], " ", "=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Cof", ",", "IntCof"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       SubscriptBox["Cof", 
        RowBox[{"1", ",", "1"}]], " ", "=", " ", 
       RowBox[{"Coefficient", "[", 
        RowBox[{
         SubscriptBox["F", "1"], ",", "\[Epsilon]", ",", "1"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       SubscriptBox["Cof", 
        RowBox[{"2", ",", "1"}]], "=", " ", 
       RowBox[{"Coefficient", "[", 
        RowBox[{
         SubscriptBox["F", "2"], ",", "\[Epsilon]", ",", "1"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       SubscriptBox["Cof", 
        RowBox[{"1", ",", "2"}]], " ", "=", " ", 
       RowBox[{"Coefficient", "[", 
        RowBox[{
         SubscriptBox["F", "1"], ",", "\[Epsilon]", ",", "2"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       SubscriptBox["Cof", 
        RowBox[{"2", ",", "2"}]], "=", " ", 
       RowBox[{"Coefficient", "[", 
        RowBox[{
         SubscriptBox["F", "2"], ",", "\[Epsilon]", ",", "2"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       SubscriptBox["IntCof", 
        RowBox[{"1", ",", "1"}]], " ", "=", " ", 
       RowBox[{"NCIntp", "[", 
        RowBox[{
         SubscriptBox["Cof", 
          RowBox[{"1", ",", "1"}]], ",", "1"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       SubscriptBox["f", "1"], " ", "=", 
       RowBox[{
        RowBox[{"NCIntp", "[", 
         RowBox[{
          RowBox[{
           SubscriptBox["Cof", 
            RowBox[{"2", ",", "1"}]], "-", 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"NCIntp", "[", 
              RowBox[{
               SubscriptBox["Cof", 
                RowBox[{"1", ",", "1"}]], ",", "1"}], "]"}], ",", 
             SubscriptBox["p", "2"]}], "]"}]}], ",", "2"}], "]"}], " ", "+", 
        SubscriptBox["IntCof", 
         RowBox[{"1", ",", "1"}]]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       SubscriptBox["Corr", "1"], "=", " ", 
       RowBox[{"NCExpandReplaceRepeated", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           SubscriptBox["f", "1"], "**", 
           SubscriptBox["Cof", 
            RowBox[{"1", ",", "1"}]]}], "-", 
          RowBox[{
           SubscriptBox["Cof", 
            RowBox[{"1", ",", "1"}]], "**", 
           SubscriptBox["f", "1"]}]}], ",", "gbhb"}], "]"}]}], ";", 
      RowBox[{
       SubscriptBox["Corr", "2"], "=", " ", 
       RowBox[{"NCExpandReplaceRepeated", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           SubscriptBox["f", "1"], "**", 
           SubscriptBox["Cof", 
            RowBox[{"2", ",", "1"}]]}], "-", 
          RowBox[{
           SubscriptBox["Cof", 
            RowBox[{"2", ",", "1"}]], "**", 
           SubscriptBox["f", "1"]}]}], ",", "gbhb"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       SubscriptBox["f", "2"], "=", 
       RowBox[{"NCIntp", "[", 
        RowBox[{
         RowBox[{
          SubscriptBox["Cof", 
           RowBox[{"1", ",", "2"}]], " ", "-", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", "2"}], ")"}], 
           SubscriptBox["Corr", "1"]}]}], ",", "1"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        SubscriptBox["f", "1"], ",", 
        SubscriptBox["f", "2"]}], "}"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["Pert", 
    RowBox[{"i_", ",", "j_"}]], "=", 
   RowBox[{
    RowBox[{"NCExpandReplaceRepeated", "[", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          FractionBox[
           SuperscriptBox["\[Epsilon]", "n"], 
           RowBox[{"n", "!"}]], 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             SubscriptBox["f", "1"], "+", 
             RowBox[{"\[Epsilon]", " ", 
              SubscriptBox["f", "2"]}]}], ")"}], "n"]}], "+", 
         SuperscriptBox[
          RowBox[{"O", "[", "\[Epsilon]", "]"}], "3"]}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "0", ",", "2"}], "}"}]}], "]"}], ",", "gbhb"}], 
     "]"}], "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SubscriptBox["x", "1"], "->", 
       RowBox[{
        RowBox[{"T", " ", 
         SubscriptBox["x", "i"]}], "+", 
        RowBox[{
         SubscriptBox["x", "j"], 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SuperscriptBox["T", "2"]}], ")"}]}]}]}], ",", 
      RowBox[{
       SubscriptBox["x", "2"], "->", 
       RowBox[{"T", " ", 
        SubscriptBox["x", "j"]}]}], ",", 
      RowBox[{
       SubscriptBox["p", "1"], "->", 
       SubscriptBox["y", "i"]}], ",", 
      RowBox[{
