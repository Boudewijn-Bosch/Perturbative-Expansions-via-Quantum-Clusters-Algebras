Cell[BoxData[
 RowBox[{
  SubscriptBox["\[DoubleStruckCapitalE]", 
   RowBox[{
    RowBox[{"{", "}"}], "\[Rule]", 
    RowBox[{"{", "1", "}"}]}]], "[", 
  RowBox[{"0", ",", 
   InterpretationBox[
    RowBox[{
     FractionBox[
      SuperscriptBox["T", "2"], 
      RowBox[{"1", "-", 
       SuperscriptBox["T", "2"], "+", 
       SuperscriptBox["T", "4"]}]], "+", 
     FractionBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", 
          SuperscriptBox["T", "2"]}], "-", 
         RowBox[{"4", " ", 
          SuperscriptBox["T", "4"]}], "+", 
         RowBox[{"4", " ", 
          SuperscriptBox["T", "6"]}], "-", 
         RowBox[{"4", " ", 
          SuperscriptBox["T", "8"]}], "+", 
         RowBox[{"2", " ", 
          SuperscriptBox["T", "10"]}]}], ")"}], " ", "\[Epsilon]"}], 
      RowBox[{"1", "-", 
       RowBox[{"3", " ", 
        SuperscriptBox["T", "2"]}], "+", 
       RowBox[{"6", " ", 
        SuperscriptBox["T", "4"]}], "-", 
       RowBox[{"7", " ", 
        SuperscriptBox["T", "6"]}], "+", 
       RowBox[{"6", " ", 
        SuperscriptBox["T", "8"]}], "-", 
       RowBox[{"3", " ", 
        SuperscriptBox["T", "10"]}], "+", 
       SuperscriptBox["T", "12"]}]], "+", 
     FractionBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", 
          SuperscriptBox["T", "2"]}], "-", 
         RowBox[{"8", " ", 
          SuperscriptBox["T", "4"]}], "+", 
         RowBox[{"14", " ", 
          SuperscriptBox["T", "6"]}], "-", 
         RowBox[{"24", " ", 
          SuperscriptBox["T", "8"]}], "+", 
         RowBox[{"36", " ", 
          SuperscriptBox["T", "10"]}], "-", 
         RowBox[{"24", " ", 
          SuperscriptBox["T", "12"]}], "+", 
         RowBox[{"14", " ", 
          SuperscriptBox["T", "14"]}], "-", 
         RowBox[{"8", " ", 
          SuperscriptBox["T", "16"]}], "+", 
         RowBox[{"2", " ", 
          SuperscriptBox["T", "18"]}]}], ")"}], " ", 
       SuperscriptBox["\[Epsilon]", "2"]}], 
      RowBox[{"1", "-", 
       RowBox[{"5", " ", 
        SuperscriptBox["T", "2"]}], "+", 
       RowBox[{"15", " ", 
        SuperscriptBox["T", "4"]}], "-", 
       RowBox[{"30", " ", 
        SuperscriptBox["T", "6"]}], "+", 
       RowBox[{"45", " ", 
        SuperscriptBox["T", "8"]}], "-", 
       RowBox[{"51", " ", 
        SuperscriptBox["T", "10"]}], "+", 
       RowBox[{"45", " ", 
        SuperscriptBox["T", "12"]}], "-", 
       RowBox[{"30", " ", 
        SuperscriptBox["T", "14"]}], "+", 
       RowBox[{"15", " ", 
        SuperscriptBox["T", "16"]}], "-", 
       RowBox[{"5", " ", 
        SuperscriptBox["T", "18"]}], "+", 
       SuperscriptBox["T", "20"]}]], "+", 
     InterpretationBox[
      SuperscriptBox[
       RowBox[{"O", "[", "\[Epsilon]", "]"}], "3"],
      SeriesData[$CellContext`\[Epsilon], 0, {}, 0, 3, 1],
      Editable->False]}],
    SeriesData[$CellContext`\[Epsilon], 
     0, {$CellContext`T^2/(
      1 - $CellContext`T^2 + $CellContext`T^4), (2 $CellContext`T^2 - 
       4 $CellContext`T^4 + 4 $CellContext`T^6 - 4 $CellContext`T^8 + 
       2 $CellContext`T^10)/(1 - 3 $CellContext`T^2 + 6 $CellContext`T^4 - 
      7 $CellContext`T^6 + 6 $CellContext`T^8 - 
      3 $CellContext`T^10 + $CellContext`T^12), (2 $CellContext`T^2 - 
       8 $CellContext`T^4 + 14 $CellContext`T^6 - 24 $CellContext`T^8 + 
       36 $CellContext`T^10 - 24 $CellContext`T^12 + 14 $CellContext`T^14 - 
       8 $CellContext`T^16 + 2 $CellContext`T^18)/(1 - 5 $CellContext`T^2 + 
      15 $CellContext`T^4 - 30 $CellContext`T^6 + 45 $CellContext`T^8 - 
      51 $CellContext`T^10 + 45 $CellContext`T^12 - 30 $CellContext`T^14 + 
      15 $CellContext`T^16 - 5 $CellContext`T^18 + $CellContext`T^20)}, 0, 3, 
     1],
    Editable->False]}], "]"}]], "Output",
